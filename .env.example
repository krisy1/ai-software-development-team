# ── Required ──────────────────────────────────────────────────
# LLM API key for agents (OpenAI, Groq, or any OpenAI-compatible provider)
OPENAI_API_KEY=your-api-key-here

# ── Optional (defaults shown) ────────────────────────────────
# Base URL for OpenAI-compatible API (e.g., Groq: https://api.groq.com/openai/v1)
# Leave empty to use OpenAI's default endpoint
OPENAI_BASE_URL=
# Model name (Groq example: llama3-70b-8192)
OPENAI_MODEL=gpt-4-turbo-preview

# Database — overridden in Docker; only needed for local runs
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ai_dev_team

# Redis — overridden in Docker; only needed for local runs
REDIS_URL=redis://localhost:6379/0

# ChromaDB — overridden in Docker; only needed for local runs
CHROMA_HOST=localhost
CHROMA_PORT=8000

# API
API_HOST=0.0.0.0
API_PORT=8000

# ── Security (REQUIRED: generate strong random values) ─────
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
API_KEY=

# CORS origins (JSON array)
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# Logging
LOG_LEVEL=info
LOG_FORMAT=json
